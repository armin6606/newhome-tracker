generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Builder {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  websiteUrl  String
  communities Community[]
  createdAt   DateTime    @default(now())
}

model Community {
  id            Int               @id @default(autoincrement())
  builderId     Int
  builder       Builder           @relation(fields: [builderId], references: [id])
  name          String
  city          String
  state         String
  url           String
  firstDetected DateTime          @default(now())
  lastUpdated   DateTime          @updatedAt
  // ── Authoritative counts (source: Table 2 baseline + scraper increments) ──
  soldCount     Int               @default(0)   // Table 2 baseline; scraper auto-increments on sale
  futureCount   Int               @default(0)   // Table 2 only; site never modifies
  totalCount    Int               @default(0)   // Table 2 only; fixed forever
  lastScrapedAt DateTime?                        // Timestamp of last successful scraper run
  listings      Listing[]
  follows       CommunityFollow[]

  @@unique([builderId, name])
  @@index([builderId])
  @@index([lastScrapedAt])
}

model Listing {
  id            Int            @id @default(autoincrement())
  communityId   Int
  community     Community      @relation(fields: [communityId], references: [id])
  address       String?
  lotNumber     String?
  floorPlan     String?
  sqft          Int?
  beds          Float?
  baths         Float?
  garages       Int?
  floors        Int?
  currentPrice  Int?
  pricePerSqft  Int?
  propertyType  String?
  hoaFees       Int?
  taxes         String?
  moveInDate    String?
  schools       String?
  incentives    String?
  incentivesUrl String?
  status        String         @default("for sale")
  sourceUrl     String?
  firstDetected DateTime       @default(now())
  lastUpdated   DateTime       @updatedAt
  soldAt        DateTime?
  priceHistory  PriceHistory[]
  favorites     UserFavorite[]

  @@unique([communityId, address])
  @@unique([communityId, lotNumber])
  @@index([communityId])
  @@index([status])
  @@index([currentPrice])
  @@index([firstDetected])
  @@index([soldAt])
  @@index([status, currentPrice])
  @@index([communityId, status])
}

model PriceHistory {
  id         Int      @id @default(autoincrement())
  listingId  Int
  listing    Listing  @relation(fields: [listingId], references: [id])
  price      Int
  oldPrice   Int?
  changeType String
  detectedAt DateTime @default(now())

  @@index([listingId])
  @@index([detectedAt])
}

model UserFavorite {
  id        Int      @id @default(autoincrement())
  userId    String
  listingId Int
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

model CommunityFollow {
  id          Int       @id @default(autoincrement())
  userId      String
  communityId Int
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, communityId])
  @@index([userId])
}

model DailySnapshot {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  data      Json

  @@map("daily_snapshots")
}

model HourlySnapshot {
  id         Int      @id @default(autoincrement())
  capturedAt DateTime @default(now())
  hourPdt    Int      // 0-23 Pacific hour
  datePdt    String   // YYYY-MM-DD Pacific date
  data       Json     // SnapshotListing[]

  @@index([datePdt])
  @@map("hourly_snapshots")
}

model NotificationLog {
  id          Int      @id @default(autoincrement())
  userId      String
  type        String   // "new_listing" | "price_drop" | "sold" | etc.
  listingId   Int?
  communityId Int?
  emailSentTo String?
  payload     Json?
  sentAt      DateTime @default(now())

  @@index([userId])
  @@index([sentAt])
  @@map("notification_logs")
}

model SchoolRating {
  id       Int      @id @default(autoincrement())
  name     String   @unique
  state    String   @default("CA")
  rating   Int?
  gsUrl    String?
  cachedAt DateTime @default(now())

  @@index([state])
  @@map("school_ratings")
}

model PromoSubmission {
  id              Int       @id @default(autoincrement())
  status          String    @default("pending") // pending | approved | rejected
  source          String    @default("email")
  sourceMessageId String?
  sourceFrom      String?
  sourceSubject   String?
  sourceDate      DateTime?
  rawSnippet      String?
  builderName     String?
  communityName   String?
  offerText       String
  offerUrl        String?
  expiresAt       DateTime?
  confidence      Float?
  notes           String?
  affectedListings Int      @default(0)
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([builderName])
  @@index([createdAt])
  @@map("promo_submissions")
}

model NewsletterSubscriber {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  firstName   String?
  lastName    String?
  subscribedAt DateTime @default(now())
  unsubscribed Boolean  @default(false)
  unsubscribedAt DateTime?

  @@index([email])
  @@map("newsletter_subscribers")
}
